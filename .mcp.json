{
  "mcpServers": {
    "chat-survivor-local": {
      "command": "uv",
      "args": ["run", "python", "-m", "mcp_service.server"],
      "env": { "MCP_LOCAL": "true" }
    },
    "chat-survivor-deployed": {
      "type": "http",
      "url": "https://thechatsurvivor.com/mcp/",
      "headers": { "Authorization": "Bearer ${MCP_AUTH}" }
    }
  }
}
