# Copy this file to .env and fill in your values.

# --- Required for the WEB frontend version ---
DEV_MODE=false                  # default false; true = verbose errors
GAME_ENABLED=true               # default true
TRANSCRIPTION_ENABLED=false     # default false

#cloudflare for web security
TURNSTILE_ENABLED=false      
TURNSTILE_SECRET=unused
#Usage limits
CHECK_IP=false                  # default false
MAX_CONCURRENT_GAMES=5          # default 5
DAILY_GAME_CAP=100              # default 100
MAX_TOKENS_PER_GAME=1500000     # default 1500000 (per-game token cap)
# ALLOWED_ORIGINS=http://localhost:5173



# --- Gemini API ! ---

# --- Option A: Gemini API key (easiest) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# If this is is, it takes priority over Vertex (below).

# --- Option B: Vertex AI (GCP) ---
# Used only when GEMINI_API_KEY is empty. Requires a GCP project with
# Vertex AI enabled, plus credentials via either:
#   - `gcloud auth application-default login`, or
#   - GOOGLE_APPLICATION_CREDENTIALS pointing at a service-account JSON.
PROJECT=your-gcp-project-id
LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

